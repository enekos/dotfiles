[push]
	autoSetupRemote = true
[user]
	name = Eneko Sarasola
	email = 113593779+enekos@users.noreply.github.com
[filter "lfs"]
	required = true
	clean = git-lfs clean -- %f
	smudge = git-lfs smudge -- %f
	process = git-lfs filter-process
[init]
	defaultBranch = master
[core]
	pager = delta
	excludesfile = /Users/enekosarasola/.gitignore_global
[interactive]
	diffFilter = delta --color-only
[delta]
	navigate = true
	light = false
[merge]
	conflictstyle = diff3
[diff]
	colorMoved = default
